{
  "name": "golfcart",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "turbo test --parallel",
    "test:watch": "turbo test:watch --parallel",
    "typecheck": "turbo typecheck",
    "dev": "turbo dev --parallel --filter=@golfcart/web --filter=@golfcart/api --filter=@golfcart/worker",
    "dev:web": "turbo dev --filter=@golfcart/web --parallel",
    "dev:api": "turbo dev --filter=@golfcart/api --parallel",
    "build": "turbo build --parallel",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.1.0",
    "emoji-regex": "^10.6.0",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@voidzero-dev/vite-plus-darwin-arm64": "0.1.21",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "date-fns": "^4.1.0",
    "@tanstack/query-core": "5.90.16"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/query-core": "5.96.2",
      "@tanstack/react-query": "5.96.2"
    }
  },
  "packageManager": "pnpm@11.12.0"
}
